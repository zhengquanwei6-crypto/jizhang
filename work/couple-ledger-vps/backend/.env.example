# Copy to .env on the VPS or local backend runtime.

JWT_SECRET=change-me-to-a-long-random-secret
JWT_SECRET_FILE=/var/lib/couple-ledger/.jwt_secret
DB_PATH=/var/lib/couple-ledger/ledger.db

APP_BASE_URL=http://127.0.0.1:8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080

TZ_OFFSET_HOURS=8
RATE_LIMIT_PER_MINUTE=120

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

ADMIN_EMAILS=
DEV_MODE=false
API_VERSION=2.2.0-beta
MIN_ANDROID_VERSION=1.0.0
MIN_ANDROID_BUILD=100
